classDiagram
    class Owner {
        +String name
        +List~Pet~ pets
        +add_pet(pet)
        +remove_pet(pet_name)
        +get_all_tasks()
    }

    class Pet {
        +String name
        +String species
        +int age
        +List~Task~ tasks
        +add_task(task)
        +remove_task(task_title)
        +get_tasks()
    }

    class Task {
        +String title
        +String notes
        +String date
        +String time
        +String frequency
        +Boolean completed
        +mark_complete()
    }

    class Scheduler {
        +Owner owner
        +get_schedule()
        +sort_by_time(tasks)
        +filter_tasks(tasks, pet_name, completed)
        +detect_conflicts(tasks)
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : organizes tasks for